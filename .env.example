# =============================================================================
# Configuration for the multi-account Outlook / Microsoft 365 MCP server.
# Copy to a local, untracked location and adapt. All knobs are env vars
# (spec §12 / provider-mapping §5). Names use the OUTLOOK_* prefix; the
# neutral meaning (MAIL_MCP_*) is preserved.
# =============================================================================

# Where tokens + app-registration configs live. Created owner-only (700);
# the token store within is written owner-only (600). (NFR-SEC-1)
# Default when unset: ~/.outlook-mcp
OUTLOOK_MCP_DATA_DIR=

# Pin a single app-registration config file; disables auto-discovery of
# multiple credential sources. Leave unset to auto-discover all configs in
# the data dir (supports accounts across different Entra app registrations —
# FR-ID-6). (spec §12: MAIL_OAUTH_CREDENTIALS)
OUTLOOK_OAUTH_CREDENTIALS=

# Allow-list directory for reading attachments supplied by local *path*.
# UNSET = path attachments are DISABLED (inline base64 still works). Paths are
# fully resolved and must fall within this directory before reading.
# (NFR-SEC-3/4) Use the OS path separator to list multiple directories.
OUTLOOK_MCP_ATTACHMENTS_DIR=

# Max milliseconds to wait for the cross-process token-store lock before
# failing a write. (NFR-SEC-2) Default: 12000
OUTLOOK_MCP_LOCK_TIMEOUT_MS=

# Per-request timeout (ms) bounding every Microsoft Graph API call.
# (NFR-REL-1) Default: 30000
OUTLOOK_MCP_REQUEST_TIMEOUT_MS=
