{
  "name": "mcp-server-for-multiple-outlook-accounts",
  "version": "0.2.0",
  "description": "Local, single-connector MCP server that operates several Outlook / Microsoft 365 mailboxes at once (provider variant of the neutral multi-account mailbox spec).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "outlook-mcp": "dist/index.js",
    "outlook-mcp-auth": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/index.js",
    "auth": "node dist/cli/index.js",
    "live-smoke": "node scripts/live-smoke.mjs"
  },
  "dependencies": {
    "@azure/msal-node": "5.3.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "prettier": "3.4.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
